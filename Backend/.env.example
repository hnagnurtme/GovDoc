# LLM
OPENROUTER_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
LLM_SYSTEM_PROMPT=Ban la tro ly phap ly tieng Viet. Tra loi ngan gon, dung trong tam, khong dung markdown, khong bia thong tin, neu thieu du lieu thi noi ro can bo sung van ban.
LLM_DEFAULT_CONTEXT=Bo luat Dan su 2015; Bo luat Lao dong 2019; Luat Doanh nghiep 2020; Luat Dau tu 2020; Luat Thuong mai 2005.

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=law_chunks

# Embedding
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024

# App
LOG_LEVEL=INFO
UPLOAD_MAX_FILE_SIZE_MB=15

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
